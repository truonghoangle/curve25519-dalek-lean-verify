import PrimeCert

/-! # Primality certificates for Curve25519

Two primality proofs we depend on:
* `2^255 - 19`, the field prime for Curve25519.
* `2^252 + 27742317777372353535851937790883648493`, the order of the Ed25519 base point.
-/

set_option linter.style.longLine false

namespace PrimeCert

/-- The Curve25519 field prime `p = 2^255 - 19` is prime. -/
theorem prime_p : Nat.Prime (2 ^ 255 - 19) := prime_cert%
  [small {2; 3; 5; 7; 43},
  pock3 (430751, 17, 1, 7, 2 * 5^3),
  pock3 (1923133, 2, 1, 5, 2^2 * 3 * 43),
  pock3 (31757755568855353, 10, 1, 5, 2 ^ 3 * 430751),
  pock3 (74058212732561358302231226437062788676166966415465897661863160754340907,
    2, 1, 5, 2 * 3 * 1923133 * 31757755568855353),
  pock (57896044618658097711785492504343953926634992332820282019728792003956564819949,
    2, 74058212732561358302231226437062788676166966415465897661863160754340907)]

/-- The Ed25519 base point order `L = 2^252 + 27742317777372353535851937790883648493` is prime. -/
theorem prime_L : Nat.Prime (2 ^ 252 + 27742317777372353535851937790883648493) := pock%
  [5, 17, 73;
  (2551, 2, 5 ^ 2 * 17),
  (3797, 2, 73),
  (531581, 2, 3797),
  (1224481, 2, 2551),
  (1257559732178653, 2, 531581 * 1224481),
  (4434155615661930479, 2, 1257559732178653),
  (172054593956031949258510691, 2, 4434155615661930479),
  (19757330305831588566944191468367130476339, 2, 172054593956031949258510691),
  (276602624281642239937218680557139826668747, 2, 19757330305831588566944191468367130476339),
  (7237005577332262213973186563042994240857116359379907606001950938285454250989, 2,
    276602624281642239937218680557139826668747)]

end PrimeCert
